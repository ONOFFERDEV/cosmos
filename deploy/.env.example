# deploy/.env 로 복사해 값을 채운 뒤 `docker compose --env-file deploy/.env ...` 로 사용.

# [필수] 관리자 부트스트랩 토큰 — 최초 로그인·관리 작업에 사용. 길고 무작위한 값으로.
COSMOS_TOKEN=바꿔주세요

# [필수 권장] 외부에서 접속하는 주소 — 초대 링크·가이드 문서·AI 런북에 이 값이 박혀 나간다.
COSMOS_PUBLIC_URL=http://localhost:8800

# [권장] mind 포트 바인딩 주소. 공인 회선이 물린 서버라면 반드시 내부망 IP로 제한할 것
# (Docker는 방화벽(firewalld)을 우회해 포트를 노출한다).
COSMOS_BIND=0.0.0.0

# [선택] 슬랙 초대 봇(자기소멸 초대 DM). 미설정 시 초대 기능만 비활성 — 나머지는 정상.
# 필요한 봇 스코프: chat:write, im:write, users:read
SLACK_BOT_TOKEN=

# [선택] 개인 지식 레포 커넥터 — org private 레포를 읽을 공용 토큰
# (GitHub fine-grained PAT, 대상 레포 contents:read 전용). 미설정 시 공개 레포만 연결 가능.
GITHUB_KNOWLEDGE_TOKEN=

# [선택] 팀원 지식 레포 템플릿("Use this template" 대상). 가이드·AI 런북에 치환되어 나간다.
COSMOS_TEMPLATE_REPO=ONOFFERDEV/knowledge-template

# [필수] LLM 키 — 클러스터 라벨링·Q&A·다이제스트에 사용 (https://console.anthropic.com)
ANTHROPIC_API_KEY=
